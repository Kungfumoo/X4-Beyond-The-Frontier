<?xml version="1.0" encoding="utf-8"?>
<diff>
    <add sel="//soundlibrary">
        <!-- no repeat is intentional, will cover cases that I've missed to stop music & docking won't take that long anyways -->
        <sound id="music_legacy_docking" description="Music from XBTF for docking" repeat="1" is3d="0" preload="0">
            <sample start="extensions\x4_btf\music\legacy\00014"/>
            <volume start="0.8"/>
            <effects>
                <fade in="1.66667" out="0.666667"/>
            </effects>
        </sound>

        <!-- docking voices -->
        <sound id="voice_argon_station" description="XBTF Argon Trading Station welcome" repeat="1" is3d="1" preload="0">
            <sample start="extensions\x4_btf\voice\argon-dock"/>
            <effects>
                <reverb room="sewer pipe" roomsize="10" drymix="5" density="90"/>
            </effects>
        </sound>

        <sound id="voice_boron_station" description="XBTF Boron Trading Station welcome" repeat="1" is3d="1" preload="0">
